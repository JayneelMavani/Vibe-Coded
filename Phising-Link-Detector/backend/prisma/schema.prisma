generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model ScanHistory {
  id              Int      @id @default(autoincrement())
  url             String
  riskLevel       String
  confidenceScore Int
  triggeredRules  String
  createdAt       DateTime @default(now())
}
